<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FF4081">

        <TextView
            android:id="@+id/tvDetailBusinessName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Име"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailBusinessCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Категорија"
            android:textColor="#FCE4EC"
            android:textSize="15sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBusinessProducts"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:padding="4dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabOrder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_dialog_email"
        android:backgroundTint="#FF4081"
        app:tint="#FFFFFF"
        android:contentDescription="Испрати нарачка" />

</RelativeLayout>